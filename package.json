{
  "name": "@aliasjeff/acli",
  "version": "1.3.0",
  "engines": {
    "node": ">=23.0.0"
  },
  "bin": {
    "acli": "./bin/acli.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup && copyfiles -u 1 \"src/builtin-skills/**/*\" \"src/builtin-rules/**/*\" \"src/builtin-subagents/**/*\" dist/",
    "start": "node ./bin/acli.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "test": "node --experimental-strip-types --test src/**/*.test.ts",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "AI CLI Assistant",
  "type": "module",
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/openai": "^3.0.48",
    "@clack/prompts": "^1.1.0",
    "ai": "^6.0.140",
    "better-sqlite3": "^12.8.0",
    "cac": "^7.0.0",
    "clipboardy": "^5.3.1",
    "conf": "^15.1.0",
    "dotenv": "^17.3.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "ignore": "^7.0.5",
    "js-tiktoken": "^1.0.21",
    "openai": "^6.33.0",
    "ora": "^9.3.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "pino-roll": "^4.0.0",
    "shell-quote": "^1.8.3",
    "tavily": "^1.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/shell-quote": "^1.7.5",
    "copyfiles": "^2.4.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
